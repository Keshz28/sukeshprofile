# ── Content Studio environment ───────────────────────────────────────────────
# Copy to `.env.local` for local dev, and set these as Environment Variables in
# the Studio's Vercel project. NEVER commit real values.

# The password you'll type to unlock the editor. Make it long & unique.
STUDIO_PASSWORD=change-me-to-a-long-random-password

# A GitHub token that may write to your portfolio repo.
# Fine-grained PAT → Repository access: only your portfolio repo →
# Permissions → Contents: Read and write.  (https://github.com/settings/tokens)
GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxx

# Which repo + file the Studio edits. This must be the repo your PORTFOLIO's
# Vercel project deploys from, so a commit here triggers a redeploy.
GITHUB_REPO=Keshz28/sukeshprofile
GITHUB_BRANCH=main
CONTENT_PATH=lib/content.json

# Optional — the author shown on the auto-commits.
GIT_AUTHOR_NAME=Content Studio
GIT_AUTHOR_EMAIL=studio@users.noreply.github.com
